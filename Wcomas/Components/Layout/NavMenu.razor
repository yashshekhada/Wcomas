@using Wcomas.Models
@using Wcomas.Services
@inject CategoryService CategoryService
@rendermode InteractiveServer

<nav class="top-row navbar navbar-light navbar-expand-lg py-1 px-4 border-bottom" style="min-height: 60px;">
    <div class="container-fluid">
        <a class="navbar-brand" href="">WCOMAS</a>
        
        <button class="navbar-toggler" type="button" @onclick="() => ExpandNav = !ExpandNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end @(ExpandNav ? "show" : "")" id="navbarNav">
            <ul class="navbar-nav align-items-center">
                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <li class="nav-item px-2">
                            <a class="nav-link" href="/category/@cat.Id">@cat.Name.ToUpper()</a>
                        </li>
                    }
                }
                <li class="nav-item px-2">
                    <NavLink class="nav-link" href="/#contact">CONTACT</NavLink>
                </li>
            </ul>
        </div>
    </div>
</nav>

<style>
    .navbar-nav .nav-link {
        color: var(--text-muted);
        font-weight: 700;
        font-size: 0.8rem;
        letter-spacing: 1.5px;
        transition: color 0.3s ease;
        padding-top: 1.5rem;
        padding-bottom: 1.5rem;
    }

    .navbar-nav .nav-link:hover, .navbar-nav .nav-link.active {
        color: var(--primary) !important;
    }

    .navbar-brand {
        font-weight: 900;
        color: var(--primary) !important;
        font-size: 1.3rem;
        letter-spacing: 2px;
    }

    .dropdown-menu {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
    }
    .dropdown-item {
        color: var(--text-muted);
        letter-spacing: 1px;
        transition: 0.3s;
        border-radius: 8px;
    }
    .dropdown-item:hover {
        background: var(--primary);
        color: white !important;
    }
</style>

@code {
    private List<Category>? categories;
    private bool ExpandNav = false;

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetAllCategoriesAsync();
    }
}