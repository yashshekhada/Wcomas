@page "/admin/categories"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Wcomas.Models
@using Wcomas.Services
@inject CategoryService CategoryService
@inject IWebHostEnvironment Env
@layout Wcomas.Components.Layout.AdminLayout
@rendermode InteractiveServer

<PageTitle>Admin | Categories</PageTitle>

<div class="reveal active">
    @if (showForm)
    {
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="glass-panel p-4 shadow-sm border-0">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-700 m-0" style="color: var(--primary);">@(editingCategory.Id == 0 ? "Add New Category" : "Edit Category")</h4>
                        <button class="btn btn-link text-muted p-0" @onclick="CancelEdit"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase fw-bold">Category Name</label>
                        <input @bind="editingCategory.Name" class="form-control form-glass" placeholder="e.g. Wall Panels" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase fw-bold">Description</label>
                        <textarea @bind="editingCategory.Description" class="form-control form-glass" rows="3" placeholder="Category details..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small uppercase fw-bold">Category Image</label>
                        <InputFile OnChange="HandleFileSelected" class="form-control form-glass" />
                        @if (!string.IsNullOrEmpty(editingCategory.ImageUrl))
                        {
                            <div class="mt-2 text-center p-2 border rounded" style="background:#f8f9fa;">
                                <img src="@editingCategory.ImageUrl" alt="Preview" style="max-height:100px; border-radius:8px;" />
                            </div>
                        }
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small uppercase fw-bold">Display Order</label>
                        <input type="number" @bind="editingCategory.DisplayOrder" class="form-control form-glass" />
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-premium w-100 py-3" @onclick="SaveCategory">@(editingCategory.Id == 0 ? "CREATE CATEGORY" : "UPDATE CATEGORY")</button>
                        <button class="btn btn-outline-secondary w-100 py-3" style="border-radius: 30px; font-size: 0.8rem;" @onclick="CancelEdit">CANCEL</button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="glass-panel p-4 shadow-sm border-0">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-700 m-0">Existing Categories</h5>
                        <button class="btn-premium px-4" @onclick="() => showForm = true">
                            <i class="bi bi-plus-lg me-2"></i> ADD CATEGORY
                        </button>
                    </div>
                    @if (categories == null)
                    {
                        <p class="text-muted">Loading categories...</p>
                    }
                    else if (!categories.Any())
                    {
                        <div class="text-center py-5 border-dashed" style="border-radius: 20px;">
                            <p class="text-muted m-0">No categories found. Create one to get started.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var cat in categories)
                            {
                                <div class="col-12">
                                    <div class="glass-panel d-flex justify-content-between align-items-center p-3 border-0 shadow-sm" style="background: rgba(0,0,0,0.01);">
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(cat.ImageUrl))
                                            {
                                                <div class="me-3" style="width: 50px; height: 50px; overflow: hidden; border-radius: 8px;">
                                                    <img src="@cat.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                                                </div>
                                            }
                                            <div>
                                                <h6 class="m-0 fw-700" style="color: var(--primary);">@cat.Name</h6>
                                                <small class="text-muted">@cat.Description</small>
                                            </div>
                                        </div>
                                        <div class="d-flex gap-3 align-items-center">
                                            <span class="badge bg-dark-soft text-dark border">ORDER: @cat.DisplayOrder</span>
                                            <button class="btn btn-link p-0 text-muted" @onclick="() => EditCategory(cat)"><i class="bi bi-pencil"></i></button>
                                            <button class="btn btn-link p-0 text-danger" @onclick="() => DeleteCategory(cat.Id)"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    .form-glass {
        background: #fdfdfd !important;
        border: 1px solid rgba(0,0,0,0.05) !important;
        border-radius: 12px !important;
        padding: 0.8rem !important;
    }
    .form-glass:focus {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 4px rgba(0,0,0,0.02) !important;
    }
    .bg-dark-soft { background: rgba(0,0,0,0.03); color: black; }
    .fw-700 { font-weight: 700; }
    .border-dashed { border: 2px dashed rgba(0,0,0,0.05); }
</style>

@code {
    private List<Category>? categories;
    private Category editingCategory = new();
    private bool showForm = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        categories = await CategoryService.GetAllCategoriesAsync();
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var fileName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";
            var path = Path.Combine(Env.WebRootPath, "uploads", "categories", fileName);
            
            using var stream = file.OpenReadStream(10 * 1024 * 1024); // 10MB max
            using var fileStream = new FileStream(path, FileMode.Create);
            await stream.CopyToAsync(fileStream);
            
            editingCategory.ImageUrl = $"/uploads/categories/{fileName}";
        }
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(editingCategory.Name)) return;

        if (editingCategory.Id == 0)
        {
            await CategoryService.CreateCategoryAsync(editingCategory);
        }
        else
        {
            await CategoryService.UpdateCategoryAsync(editingCategory);
        }

        editingCategory = new();
        showForm = false;
        await LoadCategories();
    }

    private void EditCategory(Category cat)
    {
        editingCategory = new Category
        {
            Id = cat.Id,
            Name = cat.Name,
            Description = cat.Description,
            DisplayOrder = cat.DisplayOrder,
            ImageUrl = cat.ImageUrl,
            CreatedAt = cat.CreatedAt
        };
        showForm = true;
    }

    private async Task DeleteCategory(int id)
    {
        await CategoryService.DeleteCategoryAsync(id);
        await LoadCategories();
    }

    private void CancelEdit()
    {
        editingCategory = new();
        showForm = false;
    }
}
