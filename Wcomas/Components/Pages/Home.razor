@page "/"
@using Wcomas.Models
@using Wcomas.Services
@inject InquiryService InquiryService
@inject BrandService BrandService
@inject CategoryService CategoryService
@inject ProductService ProductService
@rendermode InteractiveServer

<PageTitle>Wcomas | Premium B2B Architectural Components & Panels</PageTitle>

<HeadContent>
    <meta name="description" content="WCOMAS revolutionizes architectural spaces with premium PVC fluted panels, luxury louvers, and bespoke interior finishes. Get a B2B quote today for wholesale pricing and nationwide delivery." />
    <meta property="og:title" content="WCOMAS - Premium B2B Architectural Panels & Louvers" />
    <meta property="og:description" content="Explore our elite collection of architectural components tailored for business, retail, and luxury homes." />
    <meta property="og:url" content="https://wcomas.com" />
    <meta property="og:type" content="website" />
    
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@graph": [
        {
          "@@type": "Organization",
          "name": "WCOMAS",
          "url": "https://wcomas.com",
          "logo": "https://wcomas.com/assets/logo.png",
          "contactPoint": {
            "@@type": "ContactPoint",
            "telephone": "+91-98765-00000",
            "contactType": "customer service",
            "areaServed": "IN",
            "availableLanguage": ["en", "hi"]
          }
        },
        {
          "@@type": "WebSite",
          "url": "https://wcomas.com",
          "name": "Wcomas Premium Boards",
          "potentialAction": {
            "@@type": "SearchAction",
            "target": "https://wcomas.com/search?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      ]
    }
    </script>
</HeadContent>
<div class="hero-section">
    <img src="images/hero.png" class="hero-video-bg" alt="Luxury Interior" />
    <div class="hero-gradient-overlay"></div>
    <div class="hero-content">
        <div class="reveal" style="max-width: 900px;">
            <span style="color: var(--primary); font-weight: 800; letter-spacing: 6px; display: block; margin-bottom: 2rem; font-size: 1.1rem;">ESTABLISHED EXCELLENCE</span>
            <h1 style="font-size: clamp(4rem, 12vw, 8rem); line-height: 0.9; margin-bottom: 2.5rem; letter-spacing: -2px;">WCOMAS</h1>
            <p style="font-size: 1.8rem; margin-bottom: 4rem; color: var(--text-muted); max-width: 700px; font-weight: 300; line-height: 1.6;">
                Revolutionizing architectural spaces with premium PVC fluted panels and bespoke furniture finishes.
            </p>
            <div class="d-flex gap-4 flex-wrap">
                <a href="#collections" class="btn-premium">View Collections</a>
                <a href="#contact" class="btn-premium btn-outline">Business Inquiry</a>
            </div>
        </div>
    </div>
</div>

<!-- Brand Scroller Right After Hero -->
<div id="brands-showcase" class="py-2 bg-white border-bottom reveal w-100">
    <div class="brand-marquee">
        <div class="brand-track" style="animation-duration: @(brands != null && brands.Any() ? (brands.Count * 10 * 3) : 30)s;">
            @if (brands != null)
            {
                @for (int i = 0; i < 20; i++)
                {
                    @foreach (var b in brands)
                    {
                        <div class="brand-slide">
                            @if (!string.IsNullOrEmpty(b.LogoUrl))
                            {
                                <img src="@b.LogoUrl" alt="@b.Name" title="@b.Name" />
                            }
                            else
                            {
                                <span class="brand-text">@b.Name</span>
                            }
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>





<section id="collections" class="reveal" style="background: rgba(255,255,255,0.01); padding: 5rem 0;">
    <div class="text-center mb-5">
        <h2 style="font-size: 3.5rem; color: var(--primary); margin-bottom: 1rem;">Curated Collections</h2>
        <p style="font-size: 1.2rem; color: var(--text-muted); letter-spacing: 2px;">TRANSFORMING INTERIORS INTO ART</p>
    </div>

    <div class="product-grid mt-5">
        @if (categories != null && categories.Any())
        {
            @foreach (var c in categories)
            {
                <a href="/category/@c.Id" class="product-card text-decoration-none">
                    <img src="@(string.IsNullOrEmpty(c.ImageUrl) ? "images/hero.png" : c.ImageUrl)" alt="@c.Name">
                    <div class="product-info">
                        <h4 style="font-size: 1.8rem; color: var(--primary);">@c.Name</h4>
                        <p style="color: var(--text-main); opacity: 0.8;">@(string.IsNullOrEmpty(c.Description) ? "Explore our premium collection." : (c.Description.Length > 80 ? c.Description.Substring(0, 80) + "..." : c.Description))</p>
                    </div>
                </a>
            }
        }
        else
        {
            <div class="w-100 text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        }
    </div>
</section>

<section id="category-sliders" class="category-slider-section reveal">
    @if (categories != null && products != null)
    {
        @foreach (var category in categories)
        {
            var categoryProducts = products.Where(p => p.CategoryId == category.Id).ToList();
            @if (categoryProducts.Any())
            {
                <div class="container-fluid px-lg-10 mb-20 rounded-5 py-4" style="background: rgba(255,252,245,0.4);">
                    <div class="slider-title-area">
                        <div>
                            <span style="color: var(--primary); font-weight: 800; letter-spacing: 3px; display: block; margin-bottom: 0.5rem; font-size: 0.8rem; text-transform: uppercase;">Exclusive Collection</span>
                            <h2 style="font-size: clamp(1.5rem, 5vw, 2.5rem); color: var(--text-main); margin: 0; font-weight: 800; letter-spacing: -1px;">@category.Name</h2>
                        </div>
                        <div class="d-flex gap-3">
                            <a href="/category/@category.Id" class="text-link">VIEW ALL <i class="bi bi-arrow-right-short fs-4"></i></a>
                        </div>
                    </div>
                    
                    <div class="category-slider-container" id="slider-@category.Id">
                        <div class="category-slider-track">
                            @* Use only triple-concat for seamless manual + auto scroll *@
                            @foreach (var p in categoryProducts.Concat(categoryProducts).Concat(categoryProducts))
                            {
                                <div class="category-slider-item">
                                    <ProductCard Product="p" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    }
</section>


<section id="testimonials" class="reveal" style="padding: 5rem 0;">
    <div class="text-center mb-5">
        <h2 style="font-size: 3.5rem; color: var(--primary); margin-bottom: 1rem;">Industry Feedback</h2>
        <p style="font-size: 1.2rem; color: var(--text-muted); letter-spacing: 2px;">TRUSTED BY THE WORLD'S BEST ARCHITECTS</p>
    </div>
    
    <div class="row g-5">
        <div class="col-md-6">
            <div class="glass-panel testimonial-card">
                <p class="testimonial-quote">"Wcomas panels have completely changed our approach to commercial office design. The speed of installation is a game-changer."</p>
                <div class="testimonial-author">
                    <div class="author-img">JD</div>
                    <div>
                        <h5 style="margin: 0; color: var(--primary);">Julian Dash</h5>
                        <small style="color: var(--text-muted);">Lead Architect, Dash & Partners</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="glass-panel testimonial-card">
                <p class="testimonial-quote">"The texture depth is incredible. You can't tell it's PVC until you touch it—it feels and looks like premium stone."</p>
                <div class="testimonial-author">
                    <div class="author-img">SR</div>
                    <div>
                        <h5 style="margin: 0; color: var(--primary);">Sarah Reed</h5>
                        <small style="color: var(--text-muted);">Interior Designer, Luxe Spaces</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="reveal">
    <div class="glass-panel" style="overflow: hidden; padding: 0;">
        <div class="row g-0">
            <div class="col-lg-6 p-4 p-lg-5" style="padding: 3rem !important;">
                <h2 style="font-size: 3.5rem; color: var(--primary); margin-bottom: 1rem;">Inquire</h2>
                <p style="font-size: 1.2rem; color: var(--text-muted); margin-bottom: 4rem;">Let's discuss your next landmark project.</p>
                
                @if (submitted)
                {
                    <div class="reveal" style="text-align: center; padding: 3rem;">
                        <h3 style="color: var(--primary); margin-bottom: 1rem;">Thank You</h3>
                        <p style="color: var(--text-muted);">Your inquiry has been received. Our team will contact you shortly.</p>
                        <button type="button" class="btn-premium mt-4" @onclick="() => submitted = false">Submit Another</button>
                    </div>
                }
                else
                {
                    <form @onsubmit="SubmitInquiry">
                        <div class="mb-5">
                            <label style="color: var(--primary); font-weight: 600; margin-bottom: 1rem; display: block; letter-spacing: 1px;">FULL NAME</label>
                            <input type="text" class="form-input" placeholder="Winston Churchill" @bind="newInquiry.Name" required>
                        </div>
                        <div class="mb-5">
                            <label style="color: var(--primary); font-weight: 600; margin-bottom: 1rem; display: block; letter-spacing: 1px;">MOBILE NUMBER</label>
                            <input type="tel" class="form-input" placeholder="+91 98765 43210" @bind="newInquiry.Phone" required>
                        </div>
                        <div class="mb-5">
                            <label style="color: var(--primary); font-weight: 600; margin-bottom: 1rem; display: block; letter-spacing: 1px;">PROJECT SUMMARY</label>
                            <textarea class="form-input" rows="5" placeholder="Tell us about your requirements..." @bind="newInquiry.Message" required></textarea>
                        </div>
                        <button type="submit" class="btn-premium px-5 py-3" disabled="@isSubmitting">
                            @(isSubmitting ? "Submitting..." : "Submit Inquiry")
                        </button>
                    </form>
                }
            </div>
            <div class="col-lg-6 d-none d-lg-block" style="background: url('images/hero.png'); background-size: cover; background-position: left; position: relative;">
                <div style="position: absolute; inset: 0; background: linear-gradient(to right, var(--bg-dark), transparent);"></div>
            </div>
        </div>
    </div>
</section>


