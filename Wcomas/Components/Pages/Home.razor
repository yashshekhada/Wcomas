<style>
    .brand-card {
        background: white;
        border-radius: 20px;
        padding: 2.5rem;
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        transition: var(--transition);
        border: 1px solid rgba(0,0,0,0.03);
    }
    .brand-card img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        filter: grayscale(1) opacity(0.6);
        transition: var(--transition);
    }
    .brand-card:hover {
        transform: translateY(-8px);
        border-color: var(--primary);
    }
    .brand-card:hover img {
        filter: grayscale(0) opacity(1);
        transform: scale(1.05);
    }
    .brand-hover-info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--primary);
        color: white;
        padding: 0.8rem;
        text-align: center;
        transform: translateY(100%);
        transition: var(--transition);
    }
    .brand-card:hover .brand-hover-info {
        transform: translateY(0);
    }
    .brand-hover-info h5 {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 1px;
    }
    .brand-marquee {
        overflow: hidden;
        padding: 10px 0;
        white-space: nowrap;
        position: relative;
    }
    .brand-track {
        display: inline-flex;
        animation: scroll 30s linear infinite;
    }
    .hero-section {
        position: relative;
        height: 70vh;
        min-height: 600px;
        width: 100%;
        padding-top: 90px; /* Match navbar height */
        display: flex;
        background: #fdfcf9;
    }
    .brand-slide {

        width: 200px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 30px;
    }
    .brand-slide img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        filter: grayscale(1) opacity(0.5);
        transition: 0.3s;
    }
    .brand-slide:hover img {
        filter: grayscale(0) opacity(1);
    }
    .brand-text {
        font-weight: 800;
        color: var(--primary);
        font-size: 1.2rem;
        letter-spacing: 1px;
    }
    @@keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    .category-slider-section {
        padding: 4rem 0;
        background: transparent;
    }
    .category-slider-container {
        display: flex;
        overflow-x: auto; /* Enable native swiping */
        overflow-y: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding: 0.5rem 0;
        position: relative;
        cursor: grab;
    }
    .category-slider-container::-webkit-scrollbar {
        display: none;
    }
    .category-slider-container:active {
        cursor: grabbing;
    }
    .category-slider-track {
        display: flex;
        gap: 1.25rem; /* Tighter gap */
        width: max-content;
        will-change: scroll-position;
    }
    .category-slider-item {
        flex: 0 0 280px; /* Tighter item width */
        transition: transform 0.3s ease;
    }
    
    .mb-20 { margin-bottom: 4rem; }
    .slider-title-area {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
        border-bottom: 1px solid rgba(184, 144, 80, 0.1);
        padding-bottom: 1.5rem;
    }

    @@media (max-width: 991px) {
        .category-slider-item {
            flex: 0 0 300px;
        }
        .mb-20 { margin-bottom: 2rem; }
    }
</style>

@code {
    private Inquiry newInquiry = new();
    private List<Brand>? brands;
    private List<Category>? categories;
    private List<Product>? products;
    private Product? latestProduct;
    
    private bool isSubmitting = false;
    private bool submitted = false;

    protected override async Task OnInitializedAsync()
    {
        brands = await BrandService.GetAllBrandsAsync();
        categories = await CategoryService.GetAllCategoriesAsync();
        products = await ProductService.GetAllProductsAsync();
        latestProduct = products?.OrderByDescending(x => x.CreatedAt).FirstOrDefault();
    }

    private async Task SubmitInquiry()
    {
        isSubmitting = true;
        try
        {
            if (string.IsNullOrWhiteSpace(newInquiry.Email))
            {
                newInquiry.Email = $"{newInquiry.Phone}@no-email.local";
            }
            await InquiryService.SaveInquiryAsync(newInquiry);
            newInquiry = new();
            submitted = true;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // JS handles the auto-scroll via the script tag below
        }
    }
}

<script>
    (function() {
        function initAutoScroll() {
            const sliders = document.querySelectorAll('.category-slider-container');
            sliders.forEach(slider => {
                let isPaused = false;
                let scrollSpeed = 1.2; // Pixels per frame (~60-70px/sec) - "bit fast" as requested
                
                slider.addEventListener('mouseenter', () => isPaused = true);
                slider.addEventListener('mouseleave', () => isPaused = false);
                slider.addEventListener('touchstart', () => isPaused = true);
                slider.addEventListener('touchend', () => isPaused = false);
                
                function step() {
                    if (!isPaused) {
                        slider.scrollLeft += scrollSpeed;
                        // Reset when we've scrolled exactly one set (1/3 of total width)
                        if (slider.scrollLeft >= slider.scrollWidth / 3) {
                            slider.scrollLeft = 0;
                        }
                    }
                    requestAnimationFrame(step);
                }
                requestAnimationFrame(step);
            });
        }
        
        // Wait for page to be fully interactive
        if (document.readyState === 'complete') {
            initAutoScroll();
        } else {
            window.addEventListener('load', initAutoScroll);
        }
    })();
</script>