@page "/admin/analytics"
@using Wcomas.Services
@using Wcomas.Models
@using Microsoft.AspNetCore.Authorization
@inject UserTrackerService Tracker
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using System.Text.Json
@implements IDisposable
@attribute [Authorize(Roles = "Admin")]
@layout Wcomas.Components.Layout.AdminLayout

<PageTitle>Smart Analytics | WCOMAS</PageTitle>

<div class="analytics-container p-4">
    <!-- Header Summary Section -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="metric-card h-100">
                <div class="metric-icon bg-pulse"></div>
                <div>
                    <div class="metric-label">LIVE VISITORS</div>
                    <div class="metric-value">@activeUsers.Count</div>
                    <div class="metric-subtext">CURRENTLY ON SITE</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card h-100">
                <div class="metric-icon bi bi-graph-up text-primary"></div>
                <div>
                    <div class="metric-label">TOTAL TODAY</div>
                    <div class="metric-value">@historicalLogs.Count(l => l.CreatedAt.Date == DateTime.UtcNow.Date)</div>
                    <div class="metric-subtext">UNIQUE SESSIONS</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card h-100">
                <div class="metric-icon bi bi-globe text-info"></div>
                <div>
                    <div class="metric-label">LOCATIONS</div>
                    <div class="metric-value">@topLocations.Count</div>
                    <div class="metric-subtext">COUNTRIES REACHED</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card h-100">
                <div class="metric-icon bi bi-phone text-warning"></div>
                <div>
                    <div class="metric-label">MOBILE USERS</div>
                    <div class="metric-value">@(historicalLogs.Count > 0 ? $"{(int)(historicalLogs.Count(l => l.IsMobile) * 100.0 / historicalLogs.Count)}%" : "0%")</div>
                    <div class="metric-subtext">TRAFFIC RATIO</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Traffic Chart -->
    <div class="glass-panel p-4 mb-4" style="height: 350px;">
        <h5 class="fw-bold mb-4">Traffic Insights (Last 7 Days)</h5>
        <div style="height: 250px;">
            <canvas id="trafficChart"></canvas>
        </div>
    </div>

    <div class="row g-4">
        <!-- Live Map -->
        <div class="col-lg-8">
            <div class="glass-panel p-0 overflow-hidden" style="height: 500px; position: relative; border-radius: 20px;">
                <div id="map" style="height: 100%; z-index: 1;"></div>
                <div class="map-legend">
                    <h6 class="fw-bold m-0"><i class="bi bi-geo-alt-fill me-2"></i>Global Presence</h6>
                    <small class="text-white-50">Real-time visitor mapping</small>
                </div>
            </div>
        </div>

        <!-- Session Feed -->
        <div class="col-lg-4">
            <div class="glass-panel p-4 d-flex flex-direction-column" style="height: 500px;">
                <h5 class="fw-bold mb-4">Live Session Stream</h5>
                <div class="session-feed overflow-auto pe-2 flex-grow-1">
                    @if (!activeUsers.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-person-slash fs-1 d-block mb-2"></i>
                            <p>No active users right now</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var user in activeUsers.OrderByDescending(u => u.LastActive))
                        {
                            <div class="session-row p-3 mb-3">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold small">@user.IpAddress</span>
                                    <span class="badge @(user.IsLocated ? "badge-geo" : "bg-light text-muted")">
                                        @(user.IsLocated ? user.Country : "Locating...")
                                    </span>
                                </div>
                                <div class="small text-muted text-truncate mt-1">
                                    <i class="bi bi-eye me-1"></i> /@user.CurrentUrl
                                </div>
                                <div class="d-flex justify-content-between mt-2 x-small text-muted">
                                    <span>@(user.UserAgent.Contains("Mobile") ? "Mobile" : "Desktop")</span>
                                    <span>@GetRelativeTime(user.LastActive)</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Historical Data -->
    <div class="glass-panel p-4 mt-4">
        <h5 class="fw-bold mb-4">Visitor Log Discovery</h5>
        <div class="table-responsive">
            <table class="table table-dark-custom mb-0">
                <thead>
                    <tr>
                        <th>TIMESTAMP</th>
                        <th>LOCATION</th>
                        <th>URL PATH</th>
                        <th>IP ADDRESS</th>
                        <th>DEVICE</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in historicalLogs.Take(15))
                    {
                        <tr>
                            <td class="small">@log.CreatedAt.ToString("MMM dd HH:mm")</td>
                            <td><span class="fw-semibold">@log.City</span>, @log.Country</td>
                            <td class="text-muted font-monospace small">/@log.CurrentUrl</td>
                            <td class="small">@log.IpAddress</td>
                            <td>
                                <i class="bi @(log.IsMobile ? "bi-phone" : "bi-laptop")"></i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    :root {
        --glass-bg: #111827;
        --card-bg: #1f2937;
        --border-color: rgba(255,184,0,0.1);
        --primary-gold: #ffb800;
    }

    .analytics-container { background: #0b0f19; min-height: 100vh; color: #f3f4f6; font-family: 'Outfit', sans-serif; }
    
    .metric-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; padding: 1.5rem; display: flex; align-items: center; gap: 1.2rem; }
    .metric-icon { font-size: 1.8rem; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.03); border-radius: 12px; }
    .metric-label { font-size: 0.7rem; font-weight: 800; color: rgba(255,255,255,0.5); letter-spacing: 1px; }
    .metric-value { font-size: 1.8rem; font-weight: 800; color: var(--primary-gold); line-height: 1.2; margin: 0.2rem 0; }
    .metric-subtext { font-size: 0.6rem; color: rgba(255,255,255,0.3); font-weight: 700; }

    .bg-pulse { width: 15px; height: 15px; background: #22c55e; border-radius: 50%; box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); } 70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); } 100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); } }

    .glass-panel { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.5); }
    .map-legend { position: absolute; top: 20px; right: 20px; background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); padding: 12px 18px; border-radius: 12px; z-index: 1000; color: white; border: 1px solid var(--border-color); }
    .session-row { background: rgba(255,255,255,0.02); border-left: 3px solid var(--primary-gold); border-radius: 4px; }
    .badge-geo { background: rgba(255, 184, 0, 0.1); color: var(--primary-gold); border: 1px solid var(--border-color); }
    
    .table-dark-custom { color: #d1d5db; }
    .table-dark-custom thead th { border-bottom: 2px solid var(--border-color); color: rgba(255,255,255,0.4); font-size: 0.7rem; font-weight: 800; padding: 1.2rem; }
    .table-dark-custom td { padding: 1.2rem; border-color: rgba(255,255,255,0.03); vertical-align: middle; }
    .x-small { font-size: 0.65rem; }
    
    .session-feed::-webkit-scrollbar { width: 4px; }
    .session-feed::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
</style>

@code {
    private List<ActiveUser> activeUsers = new();
    private List<VisitorLog> historicalLogs = new();
    private List<(string Country, int Count)> topLocations = new();
    
    protected override async Task OnInitializedAsync()
    {
        Tracker.OnChange += RefreshState;
        await LoadHistoricalData();
    }

    private async Task LoadHistoricalData()
    {
        activeUsers = Tracker.GetActiveUsers();
        historicalLogs = await Tracker.GetHistoricalLogsAsync(50);
        
        topLocations = historicalLogs.Concat(activeUsers.Select(u => new VisitorLog { Country = u.Country, IsLocated = u.IsLocated }))
            .Where(u => !string.IsNullOrEmpty(u.Country) && u.Country != "Unknown")
            .GroupBy(u => u.Country)
            .Select(g => (Country: g.Key, Count: g.Count()))
            .OrderByDescending(x => x.Count)
            .ToList();
    }

    private void RefreshState()
    {
        _ = InvokeAsync(async () => {
            await LoadHistoricalData();
            StateHasChanged();
            await UpdateMap();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initMap");
            await UpdateMap();
            await UpdateChart();
        }
    }

    private async Task UpdateMap()
    {
        try {
            var usersJson = JsonSerializer.Serialize(activeUsers.Where(u => u.IsLocated));
            await JSRuntime.InvokeVoidAsync("updateMapMarkers", usersJson);
        } catch {}
    }

    private async Task UpdateChart()
    {
        try {
            var stats = await Tracker.GetTrafficStatsAsync(7);
            var labels = stats.Select(s => s.Date.ToString("MMM dd")).ToList();
            var data = stats.Select(s => s.Count).ToList();
            
            await JSRuntime.InvokeVoidAsync("initTrafficChart", JsonSerializer.Serialize(labels), JsonSerializer.Serialize(data));
        } catch {}
    }

    private string GetRelativeTime(DateTime time)
    {
        var diff = DateTime.UtcNow - time;
        if (diff.TotalSeconds < 60) return "Active";
        return $"{(int)diff.TotalMinutes}m ago";
    }

    public void Dispose()
    {
        Tracker.OnChange -= RefreshState;
    }
}
